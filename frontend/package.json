{
  "name": "md-bug-frontend",
  "version": "1.0.0",
  "description": "Markdown bug viewer frontend",
  "main": "index.js",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --outfile=public/bundle.js --loader:.tsx=tsx --loader:.ts=ts --loader:.css=css --minify --define:USE_FAKE_API=false --define:DEBUG_MODE=false",
    "build-dev": "esbuild src/index.tsx --bundle --outfile=public/bundle.js --loader:.tsx=tsx --loader:.ts=ts --loader:.css=css --define:USE_FAKE_API=false --define:DEBUG_MODE=true",
    "watch-dev": "esbuild src/index.tsx --bundle --outfile=public/bundle.js --loader:.tsx=tsx --loader:.ts=ts --loader:.css=css --define:USE_FAKE_API=false --define:DEBUG_MODE=true --watch",
    "fakeapi-build": "esbuild src/index.tsx --bundle --outfile=public/bundle.js --loader:.tsx=tsx --loader:.ts=ts --loader:.css=css --minify --define:USE_FAKE_API=true --define:DEBUG_MODE=true",
    "serve": "npx serve public"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@types/react-router-dom": "5.3.3",
    "dompurify": "3.0.8",
    "jsdom": "29.0.1",
    "marked": "17.0.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "7.13.2",
    "standard-ts-lib": "file:../../standard-ts-lib"
  },
  "devDependencies": {
    "@types/dompurify": "3.0.5",
    "@types/jsdom": "28.0.1",
    "@types/marked": "5.0.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "esbuild": "0.27.4",
    "typescript": "6.0.2"
  }
}
