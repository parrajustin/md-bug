{
  "name": "md-bug-frontend",
  "version": "1.0.0",
  "description": "Markdown bug viewer frontend",
  "main": "index.js",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --outfile=public/bundle.js --loader:.tsx=tsx --loader:.ts=ts --loader:.css=css --minify",
    "serve": "npx serve public"
  },
  "dependencies": {
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "marked": "17.0.5",
    "dompurify": "3.0.8",
    "jsdom": "29.0.1",
    "standard-ts-lib": "file:../../standard-ts-lib"
  },
  "devDependencies": {
    "esbuild": "0.27.4",
    "typescript": "6.0.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/marked": "5.0.2",
    "@types/dompurify": "3.0.5",
    "@types/jsdom": "28.0.1"
  }
}
